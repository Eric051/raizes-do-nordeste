# Variaveis de ambiente do sistema Raizes do Nordeste API
# Copie este arquivo para .env e ajuste os valores conforme necessario

# Banco de dados (SQLite por padrao, fica num arquivo na raiz do projeto)
DATABASE_URL=sqlite:///./raizes_do_nordeste.db

# Seguranca / JWT
JWT_SECRET_KEY=troque-isso-por-uma-chave-secreta-bem-grande-em-producao
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Aplicacao
APP_NAME=Raizes do Nordeste API
APP_VERSION=1.0.0
DEBUG=True

# Pagamento mock
# Valores possiveis: APROVADO, RECUSADO, ALEATORIO
PAYMENT_MOCK_DEFAULT_OUTCOME=APROVADO
